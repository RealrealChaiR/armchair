{
  "name": "armchair",
  "version": "0.0.1",
  "description": "Terminal-based dev tools written in TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "armchair": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "packageManager": "pnpm@10.30.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty"
    ]
  },
  "dependencies": {
    "@xterm/headless": "^6.0.0",
    "ink": "^7.0.0",
    "node-pty": "^1.1.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.2.1",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-turbo": "^1.13.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^7.0.0"
  }
}
